{
  "name": "copy-trading-polymarket",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts start",
    "dev": "tsx src/index.ts",
    "smoke:commands": "tsx src/index.ts --help && tsx src/index.ts list && tsx src/index.ts status",
    "smoke:logs": "tsx src/index.ts logs --commands",
    "test:base": "npm run typecheck && npm run smoke:commands && npm run smoke:logs"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "ora": "^8.0.1",
    "p-limit": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
